{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dprint-plugin-golangci Configuration",
  "type": "object",
  "properties": {
    "configPath": {
      "type": "string",
      "description": "Path to golangci-lint configuration file (.golangci.yml)"
    },
    "fix": {
      "type": "boolean",
      "default": true,
      "description": "Whether to auto-fix issues that golangci-lint can fix"
    }
  },
  "additionalProperties": false
}
